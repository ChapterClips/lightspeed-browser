{
  "name": "lightspeed-browser",
  "version": "0.1.0",
  "description": "A lightweight multi-tab desktop browser built with Electron.",
  "main": "src/main/main.js",
  "author": "Lightspeed Browser",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node --check src/main/main.js && node --check src/main/store.js && node --check src/main/preload.js && node --check src/main/page-preload.js && node --check src/renderer/app.js && node --check src/pages/page.js",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.lightspeed.browser",
    "productName": "Lightspeed Browser",
    "artifactName": "Lightspeed-Browser-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "executableName": "LightspeedBrowser"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lightspeed Browser",
      "uninstallDisplayName": "Lightspeed Browser"
    },
    "portable": {
      "artifactName": "Lightspeed-Browser-Portable-${version}-${arch}.${ext}"
    }
  }
}
